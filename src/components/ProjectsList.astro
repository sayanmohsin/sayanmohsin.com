---
import { projects } from "../data/projects"
---

<section class="mx-auto max-w-2xl px-4 py-20 sm:px-0 sm:py-28">
  <a href="/about" class="mono text-sm text-dim hover:text-fg transition-colors">&larr; about</a>

  <div class="mt-12">
    <p class="mono text-xs text-dim/60 tracking-[0.1em] uppercase">Projects</p>
    <h1 class="mt-3 text-2xl font-light tracking-tight sm:text-3xl">Things I've built</h1>
  </div>

  <div class="mt-8 space-y-6">
    {projects.map((p) => (
      <a
        href={`/projects/${p.slug}`}
        class="group block border-l border-line pl-4 transition-all duration-200 hover:border-signal"
      >
        <div class="flex items-center gap-2">
          <span class="text-base">{p.emoji}</span>
          <h2 class="text-lg font-medium text-fg group-hover:text-signal transition-colors">{p.name}</h2>
        </div>
        <p class="mt-1 text-sm text-dim">{p.tagline}</p>
        <div class="mt-1 flex flex-wrap gap-x-2 mono text-[12px] text-dim/60">
          {p.tags.map((tag) => (
            <span>{tag}</span>
          ))}
        </div>
      </a>
    ))}
  </div>

  <div class="mt-12">
    <a href="/" class="btn-outline group">
      home
      <svg class="h-3.5 w-3.5 transition-transform duration-200 group-hover:-translate-x-0.5" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
    </a>
  </div>
</section>
