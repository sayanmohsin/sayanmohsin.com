---
import ThreeCanvas from "./ThreeCanvas.astro"
---

<ThreeCanvas />

<section class="relative z-10 flex h-screen flex-col items-center justify-center overflow-hidden px-4">
  <div class="absolute top-6 right-6 z-20 flex items-center gap-4">
    <a
      href="https://github.com/sayanmohsin"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="GitHub"
      class="flex items-center justify-center hover:opacity-80 transition-opacity"
      style="filter:drop-shadow(0 0 8px rgba(255,255,255,0.3))"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="#ffffff"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
    </a>
    <a
      href="https://linkedin.com/in/sayanmohsin"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="LinkedIn"
      class="flex items-center justify-center hover:opacity-80 transition-opacity"
      style="filter:drop-shadow(0 0 8px rgba(10,102,194,0.4))"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="#0A66C2"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    </a>
  </div>

  <div class="relative text-center">
    <div class="profile-glow mx-auto mb-8 h-40 w-40 overflow-hidden rounded-full transition-shadow duration-500 sm:h-48 sm:w-48">
      <img src="/sayan-mohsin.svg" alt="Sayan Mohsin" class="h-full w-full" />
    </div>

      <h1 class="text-5xl font-light tracking-tight text-white sm:text-7xl lg:text-8xl">
        I'm Sayan Mohsin
      </h1>
    <div id="hero-subtitle" class="relative mx-auto mt-6 max-w-sm text-center font-light leading-relaxed text-[#e8e5df] sm:max-w-lg" style="text-shadow: 0 4px 20px rgba(0,0,0,0.95)"></div>

<script>
import texts from "../data/hero-texts.json"

const entry = texts[Math.floor(Math.random() * texts.length)]
const container = document.getElementById("hero-subtitle")
if (container) {
  container.innerHTML = entry.lines
    .map((line, i) => `<div>${i === 0 ? `<span class="text-signal font-mono" style="text-shadow: 0 0 8px rgba(255,107,0,0.5)">></span> ` : ""}${line}</div>`)
    .join("")
}
</script>
    <a href="/about" class="group btn-filled mt-8 inline-flex">
      there's more
      <span class="arrow-wrap relative h-3.5 w-5">
        <svg class="arrow-main absolute inset-0 h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        <svg class="arrow-ghost absolute inset-0 h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </span>
    </a>
  </div>

  <footer class="absolute bottom-6 left-0 right-0 text-center">
    <p class="mono text-xs" style="color:#ffd700; filter:drop-shadow(0 0 6px rgba(255,215,0,0.3))">Toronto, Canada</p>
  </footer>
</section>
