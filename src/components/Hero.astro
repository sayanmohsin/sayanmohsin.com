---
import ThreeCanvas from "./ThreeCanvas.astro"
---

<ThreeCanvas />

<section class="relative z-10 flex min-h-screen flex-col items-center justify-center px-4">
  <div class="profile-glow mb-8 h-24 w-24 overflow-hidden rounded-full border border-line sm:h-28 sm:w-28">
    <img src="/sayan-mohsin.jpg" alt="Sayan Mohsin" class="h-full w-full object-cover" />
  </div>

  <div class="text-center">
    <p class="mono text-xs text-dim/50 tracking-[0.1em] uppercase">Senior Software Engineer</p>
    <h1 class="mt-4 text-4xl font-light tracking-tight sm:text-5xl lg:text-6xl text-fg">
      Sayan Mohsin
    </h1>
    <p class="mx-auto mt-3 max-w-md text-base text-dim sm:text-lg">
      Building AI-native systems — from the data plane to the agent layer.
    </p>
  </div>

  <div class="mt-10 flex items-center gap-3">
    <a href="/about" class="btn-outline group">
      about me
