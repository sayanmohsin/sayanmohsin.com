---

<section class="relative min-h-screen overflow-hidden pt-0">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute -top-40 left-1/2 h-96 w-96 -translate-x-1/2 rounded-full bg-orange-500/5 blur-[128px]" />
    <div class="absolute -bottom-40 left-1/3 h-64 w-64 rounded-full bg-green-500/5 blur-[96px]" />
  </div>

  <div class="glass fixed top-0 left-0 right-0 z-50 border-b border-border/50">
    <div class="mx-auto flex h-10 max-w-5xl items-center justify-between px-4 sm:px-6">
      <div class="flex items-center gap-2">
        <span class="status-dot bg-green-500 shadow-[0_0_6px_#00ff88]" />
        <span class="font-mono text-[11px] text-text-muted">sayanmohsin.com</span>
        <span class="font-mono text-[10px] text-text-dim">v1.0</span>
      </div>
      <div class="flex items-center gap-3">
        <a href="https://github.com/sayanmohsin" target="_blank" rel="noopener noreferrer" class="font-mono text-[11px] text-text-muted transition-colors hover:text-orange-500">GitHub</a>
        <a href="https://linkedin.com/in/sayanmohsin" target="_blank" rel="noopener noreferrer" class="font-mono text-[11px] text-text-muted transition-colors hover:text-green-500">LinkedIn</a>
        <a href="mailto:sayanmohsin@outlook.com" class="font-mono text-[11px] text-text-muted transition-colors hover:text-yellow-500">Email</a>
      </div>
    </div>
  </div>

  <div class="relative z-10 mx-auto flex min-h-screen max-w-3xl flex-col items-center justify-center px-4 text-center">
    <div class="mb-8 h-28 w-28 overflow-hidden rounded-full border-2 border-orange-500/30 sm:h-32 sm:w-32">
      <div class="flex h-full w-full items-center justify-center bg-bg-card text-4xl sm:text-5xl">
        <svg class="h-14 w-14 text-text-dim sm:h-16 sm:w-16" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
      </div>
    </div>

    <div class="mb-2 font-mono text-sm text-text-muted">
      <span class="gradient-text-orange">$</span> whoami
    </div>

    <h1 class="font-display text-5xl font-bold tracking-tight sm:text-7xl lg:text-8xl">
      <span class="gradient-text-orange text-glow-orange">Sayan</span>
      <span class="gradient-text-green text-glow-green"> Mohsin</span>
    </h1>

    <p class="mt-3 max-w-lg text-base leading-relaxed text-text-muted sm:text-lg">
      Building AI-Native Systems
    </p>

    <div class="mt-8 flex items-center gap-1.5">
      {Array.from({ length: 30 }).map((_, i) => (
        <div
          class="signal-bar h-8 sm:h-12"
          style={{
            animationDelay: `${i * 0.1}s`,
            height: `${20 + Math.random() * 40}px`,
            opacity: 0.3 + Math.random() * 0.7,
          }}
        />
      ))}
    </div>

    <div class="mt-8 flex items-center gap-4">
      <a
        href="https://github.com/sayanmohsin"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 rounded-lg border border-border bg-bg-card px-4 py-2.5 font-mono text-sm text-text-muted transition-all duration-200 hover:border-orange-500/40 hover:text-orange-500 hover:glow-orange"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
      <a
        href="https://linkedin.com/in/sayanmohsin"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 rounded-lg border border-border bg-bg-card px-4 py-2.5 font-mono text-sm text-text-muted transition-all duration-200 hover:border-green-500/40 hover:text-green-500 hover:glow-green"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        LinkedIn
      </a>
      <a
        href="mailto:sayanmohsin@outlook.com"
        class="flex items-center gap-2 rounded-lg bg-orange-500 px-4 py-2.5 font-mono text-sm font-medium text-white transition-all duration-200 hover:bg-orange-400 hover:glow-orange"
      >
        Email
      </a>
    </div>

    <div class="mt-10 w-full max-w-md">
      <div class="rounded-xl border border-border bg-bg-card">
        <div class="flex items-center gap-2 border-b border-border px-4 py-2">
          <span class="panel-header"><span class="text-text-muted">~</span></span>
          <span class="font-mono text-[10px] text-text-dim">mission</span>
        </div>
        <div class="space-y-1 p-4 font-mono text-xs leading-relaxed sm:text-sm">
          <div class="text-text-dim"><span class="gradient-text-orange">$</span> cat mission.txt</div>
          <div class="flex items-start gap-2 text-text-muted">
            <span class="mt-0.5 text-orange-500">></span>
            <span>Building distributed systems with Kafka &amp; Temporal</span>
          </div>
          <div class="flex items-start gap-2 text-text-muted">
            <span class="mt-0.5 text-green-500">></span>
            <span>Designing AI agents that code, review, and deploy</span>
          </div>
          <div class="flex items-start gap-2 text-text-muted">
            <span class="mt-0.5 text-yellow-500">></span>
            <span>Shipping across full stack: backend → frontend → infra</span>
          </div>
          <div class="mt-3 flex items-center gap-1.5 text-text-muted">
            <span class="gradient-text-orange">$</span>
            <span class="text-orange-500">Ship_Fast.exe</span>
            <span class="text-text-dim">&amp;&amp;</span>
            <span class="text-green-500">Pivot_Faster.exe</span>
            <span class="ml-1 inline-block h-4 w-[7px] animate-[blink_1s_step-end_infinite] rounded-[1px] bg-orange-500" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
