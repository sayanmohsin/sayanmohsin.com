---
const socials = [
  { href: "https://github.com/sayanmohsin", label: "GitHub", icon: "github" },
  { href: "https://linkedin.com/in/sayanmohsin", label: "LinkedIn", icon: "linkedin" },
]
---

<section id="hero" class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-4 pt-16">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute -top-40 left-1/2 h-96 w-96 -translate-x-1/2 rounded-full bg-accent-500/5 blur-[128px]" />
    <div class="absolute -bottom-40 left-1/3 h-64 w-64 rounded-full bg-accent-500/5 blur-[96px]" />
  </div>

  <div class="relative z-10 mx-auto flex w-full max-w-3xl flex-col items-center text-center">
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-accent-500/20 bg-accent-500/5 px-4 py-1.5 text-xs font-medium text-accent-400/80 sm:text-sm">
      <span class="inline-block h-2 w-2 animate-pulse rounded-full bg-accent-500 shadow-[0_0_8px_#ff6b00]" />
      System Status: 100% OPERATIONAL
    </div>

    <div class="mb-4 font-mono text-sm text-text-muted">
      <span class="gradient-text">$</span> whoami
    </div>

    <h1 class="font-display text-4xl font-bold tracking-tight sm:text-6xl lg:text-7xl">
      <span class="gradient-text glow-text">Sayan Mohsin</span>
    </h1>

    <p class="mt-4 max-w-xl text-base leading-relaxed text-text-muted sm:text-lg">
      Senior Software Engineer building AI-native systems at Intellistack.
    </p>

    <div class="mt-8 flex items-center gap-4">
      {
        socials.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-2 rounded-lg border border-border bg-bg-card px-4 py-2.5 text-sm font-medium text-text-muted transition-all duration-200 hover:border-accent-500/40 hover:text-accent-400 hover:shadow-[0_0_20px_#ff6b0020]"
          >
            {s.label}
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M21 21 3 3"/><path d="M21 3l-9 9"/></svg>
          </a>
        ))
      }
    </div>

    <div class="mt-12 w-full max-w-lg">
      <div class="glow-border overflow-hidden rounded-xl border border-border bg-bg-card">
        <div class="flex items-center gap-1.5 border-b border-border px-4 py-2.5">
          <span class="h-3 w-3 rounded-full bg-red-500/80" />
          <span class="h-3 w-3 rounded-full bg-yellow-500/80" />
          <span class="h-3 w-3 rounded-full bg-green-500/80" />
          <span class="ml-2 font-mono text-xs text-text-muted">~/mission</span>
        </div>
        <div class="space-y-1.5 p-4 font-mono text-xs leading-relaxed sm:text-sm">
          <div class="text-text-muted"><span class="gradient-text">$</span> cat mission.txt</div>
          <div class="flex items-start gap-2 text-text-muted">
            <span class="mt-0.5 text-accent-400">></span>
            <span>Building distributed systems with Kafka &amp; Temporal</span>
          </div>
          <div class="flex items-start gap-2 text-text-muted">
            <span class="mt-0.5 text-accent-400">></span>
            <span>Designing AI agents that code, review, and deploy</span>
          </div>
          <div class="flex items-start gap-2 text-text-muted">
            <span class="mt-0.5 text-accent-400">></span>
            <span>Shipping across full stack: backend → frontend → infra</span>
          </div>
          <div class="mt-3 flex items-center gap-1.5 text-text-muted">
            <span class="gradient-text">$</span>
            <span class="text-accent-400">Ship_Fast.exe</span>
            <span class="opacity-60">&amp;&amp;</span>
            <span class="text-accent-400">Pivot_Faster.exe</span>
            <span class="inline-block h-5 w-2 animate-[blink_1s_step-end_infinite] bg-accent-500" />
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="h-6 w-6 text-text-muted" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
  </div>
</section>
