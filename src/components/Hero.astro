---

<section class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-4">
  <div class="glass fixed top-0 left-0 right-0 z-50 border-b border-border">
    <div class="mx-auto flex h-12 max-w-5xl items-center justify-between px-4 sm:px-6">
      <span class="text-sm font-medium text-text-primary">Sayan Mohsin</span>
      <div class="flex items-center gap-4">
        <a href="https://github.com/sayanmohsin" target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted transition-colors hover:text-text-primary">GitHub</a>
        <a href="https://linkedin.com/in/sayanmohsin" target="_blank" rel="noopener noreferrer" class="text-sm text-text-muted transition-colors hover:text-text-primary">LinkedIn</a>
        <a href="mailto:sayanmohsin@outlook.com" class="text-sm text-text-muted transition-colors hover:text-text-primary">Email</a>
      </div>
    </div>
  </div>

  <div class="z-10 mx-auto flex w-full max-w-2xl flex-col items-center text-center">
    <div class="mb-8 h-24 w-24 overflow-hidden rounded-full border border-border sm:h-28 sm:w-28">
      <div class="flex h-full w-full items-center justify-center bg-bg-surface">
        <svg class="h-12 w-12 text-text-dim sm:h-14 sm:w-14" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
      </div>
    </div>

    <div class="mb-4 font-mono text-xs text-text-muted">
      <span class="text-accent">$</span> whoami
    </div>

    <h1 class="text-4xl font-light tracking-tight sm:text-6xl lg:text-7xl">
      <span class="text-text-primary">Sayan</span>
      <span class="text-accent"> Mohsin</span>
    </h1>

    <p class="mt-4 max-w-md text-base leading-relaxed text-text-muted sm:text-lg">
      Building AI-native systems.
    </p>

    <div class="mt-10 flex items-center gap-3">
      <a
        href="https://github.com/sayanmohsin"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-lg border border-border bg-bg-card px-4 py-2.5 text-sm text-text-muted transition-all duration-200 hover:border-text-subtle hover:text-text-primary"
      >
        GitHub
      </a>
      <a
        href="https://linkedin.com/in/sayanmohsin"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-lg border border-border bg-bg-card px-4 py-2.5 text-sm text-text-muted transition-all duration-200 hover:border-text-subtle hover:text-text-primary"
      >
        LinkedIn
      </a>
      <a
        href="mailto:sayanmohsin@outlook.com"
        class="rounded-lg bg-accent px-4 py-2.5 text-sm font-medium text-white transition-all duration-200 hover:bg-accent-hover"
      >
        Email
      </a>
    </div>

    <div class="mt-14 w-full max-w-md rounded-xl border border-border bg-bg-card p-4 sm:p-5">
      <div class="flex items-center gap-2 border-b border-border pb-3">
        <span class="h-2.5 w-2.5 rounded-full bg-accent" />
        <span class="font-mono text-xs text-text-muted">~/mission</span>
      </div>
      <div class="space-y-2 pt-3 font-mono text-xs leading-relaxed sm:text-sm">
        <div class="text-text-dim"><span class="text-accent">$</span> cat mission.txt</div>
        <div class="flex items-start gap-2 text-text-muted">
          <span class="mt-0.5 shrink-0 text-accent">></span>
          <span>Building distributed systems with Kafka &amp; Temporal</span>
        </div>
        <div class="flex items-start gap-2 text-text-muted">
          <span class="mt-0.5 shrink-0 text-accent">></span>
          <span>Designing AI agents that code, review, and deploy</span>
        </div>
        <div class="flex items-start gap-2 text-text-muted">
          <span class="mt-0.5 shrink-0 text-accent">></span>
          <span>Shipping across full stack: backend → frontend → infra</span>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2">
    <svg class="h-5 w-5 text-text-dim animate-bounce" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
  </div>
</section>
