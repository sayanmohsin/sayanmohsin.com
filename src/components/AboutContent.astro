    <div class="mt-4 space-y-1 mono text-sm">
      <div><a href="mailto:sayanmohsin@outlook.com" class="text-dim hover:text-fg transition-colors">sayanmohsin@outlook.com</a></div>
      <div><a href="https://github.com/sayanmohsin" target="_blank" rel="noopener noreferrer" class="text-dim hover:text-fg transition-colors">github.com/sayanmohsin</a></div>
