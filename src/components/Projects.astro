---
import { projects } from "../data/projects"
import ProjectCard from "./ProjectCard.astro"
---

<section id="projects" class="px-4 py-24 sm:px-6 sm:py-32">
  <div class="mx-auto max-w-5xl">
    <div class="mb-14 text-center">
      <div class="mb-3 font-mono text-xs text-text-dim">/projects</div>
      <h2 class="text-2xl font-light tracking-tight text-text-primary sm:text-3xl">
        Projects
      </h2>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {projects.map((p, i) => (
        <ProjectCard project={p} index={i} />
      ))}
    </div>
  </div>
</section>
