---
import { projects } from "../data/projects"
---

<section id="projects" class="section mx-auto max-w-xl px-4 sm:px-0">
  <div class="space-y-3">
    {projects.map((p) => (
      <div class="group leading-snug">
        <a
          href={`/projects/${p.slug}`}
          class="mono text-sm"
        >
          <span class="text-dim/40">*</span>{" "}
          {p.featured ? (
            <span class="text-fg font-medium">{p.name}</span>
          ) : (
            <span class="text-fg">{p.name}</span>
          )}
        </a>
        <span class="text-dim text-[14px]"> {p.tagline}</span>
      </div>
    ))}
  </div>

  <hr class="signal" />
</section>
