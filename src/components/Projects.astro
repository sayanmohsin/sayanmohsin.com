---
import { projects } from "../data/projects"
---

<section id="projects" class="section mx-auto mt-32 max-w-2xl px-4 sm:px-0">
  <p class="mono text-xs text-dim/40 tracking-[0.1em] uppercase">Projects</p>

  <div class="mt-6 space-y-5">
    {projects.map((p) => (
      <div class="group flex items-start gap-3">
        <span class="mt-0.5 text-dim/30 mono text-sm shrink-0">*</span>
        <div class="min-w-0">
          <a
            href={`/projects/${p.slug}`}
            class="text-fg font-medium transition-colors hover:text-signal"
          >
            {p.name}
          </a>
          <span class="text-dim text-[14px]"> — {p.tagline}</span>
          <div class="mt-0.5 flex flex-wrap gap-x-2 mono text-[12px] text-dim/40">
            {p.tags.map((tag) => (
              <span>{tag}</span>
            ))}
            <a href={`/projects/${p.slug}`} class="text-dim/60 hover:text-signal transition-colors">
              details →
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
