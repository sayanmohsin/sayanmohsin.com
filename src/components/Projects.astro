---
import { projects } from "../data/projects"
import ProjectCard from "./ProjectCard.astro"
---

<section id="projects" class="relative px-4 py-24 sm:px-6 sm:py-32">
  <div class="mx-auto max-w-5xl">
    <div class="mb-12">
      <div class="panel-header mb-2">
        <span class="gradient-text-green">Services</span>
      </div>
      <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">
        <span class="gradient-text-green">Projects</span>
      </h2>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {projects.map((p, i) => (
        <ProjectCard project={p} index={i} />
      ))}
    </div>
  </div>
</section>
