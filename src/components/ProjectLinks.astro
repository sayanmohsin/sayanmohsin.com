---
import type { ProjectLink } from "../data/projects"

interface Props {
  links: ProjectLink[]
  accent: string
}

const { links, accent } = Astro.props

function icon(type: string): string {
  switch (type) {
    case "github":
      return `<svg class="h-4 w-4 shrink-0 text-[#ffd700]" style="filter:drop-shadow(0 0 6px rgba(255,215,0,0.35))" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`
    case "website":
      return `<svg class="h-4 w-4 shrink-0 text-[#ffd700]" style="filter:drop-shadow(0 0 6px rgba(255,215,0,0.35))" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`
    case "appstore":
      return `<svg class="h-4 w-4 shrink-0 text-[#ffd700]" style="filter:drop-shadow(0 0 6px rgba(255,215,0,0.35))" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2.5 14.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm2.5-10c2.21 0 4 1.79 4 4 0 .89-.25 1.71-.68 2.4l-.82-.48c.32-.56.5-1.21.5-1.92 0-1.66-1.34-3-3-3s-3 1.34-3 3c0 .89.25 1.71.68 2.4l-.82.48c-.43-.69-.68-1.51-.68-2.4 0-2.21 1.79-4 4-4z"/></svg>`
    case "playstore":
      return `<svg class="h-4 w-4 shrink-0 text-[#ffd700]" style="filter:drop-shadow(0 0 6px rgba(255,215,0,0.35))" viewBox="0 0 24 24" fill="currentColor"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.807 1.626a1 1 0 0 1 0 1.732l-2.807 1.626L15.206 12l2.492-2.492zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/></svg>`
    case "download":
      return `<svg class="h-4 w-4 shrink-0 text-[#ffd700]" style="filter:drop-shadow(0 0 6px rgba(255,215,0,0.35))" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>`
    default:
      return `<svg class="h-4 w-4 shrink-0 text-[#ffd700]" style="filter:drop-shadow(0 0 6px rgba(255,215,0,0.35))" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`
  }
}

function label(type: string, url: string): string {
  switch (type) {
    case "appstore":
      return "App Store"
    case "playstore":
      return "Play Store"
    default:
      return url.replace("https://", "")
  }
}
---

{
  links.length > 0 && (
    <div class="mt-8 space-y-1 mono text-sm">
      {links.map((link) => (
        <div class="flex items-center gap-2">
          <fragment set:html={icon(link.type)} />
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="text-dim hover:text-fg transition-colors" style={`color: ${accent}`}>
            {label(link.type, link.url)}
          </a>
        </div>
      ))}
    </div>
  )
}
