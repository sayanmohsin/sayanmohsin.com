---
const accent = "#6b80ff"
---

<div id="clipstash-downloads" data-accent={accent} class="mt-8">
  <p class="mono text-xs tracking-[0.1em] uppercase" style={`color: ${accent}80`}>Downloads</p>
  <div id="dl-list" class="mt-3 space-y-1 mono text-sm"></div>
  <div id="dl-meta" class="mt-2 text-xs text-dim/40 mono hidden"></div>
</div>

<script>
  import { fetchManifest, PLATFORMS } from "../lib/versions"

  const container = document.getElementById("clipstash-downloads")
  const list = document.getElementById("dl-list")
  const meta = document.getElementById("dl-meta")

  fetchManifest()
    .then((manifest) => {
      const latest = manifest.versions.find((v) => v.version === manifest.latest)
      if (!latest) {
        container?.remove()
        return
      }

      const lines = PLATFORMS.filter((p) => latest.files[p.key]).map((p) => {
        const file = latest.files[p.key]
        return `<div><a href="${file.url}" class="text-dim hover:text-fg transition-colors"><span class="text-dim/50">[${p.short}]</span> ${p.label}</a></div>`
      })

      if (lines.length === 0) {
        container?.remove()
        return
      }

      list.innerHTML = lines.join("")
      meta.textContent = `v${latest.version} · ${latest.date}`
      meta.classList.remove("hidden")
    })
    .catch(() => {
      container?.remove()
    })
</script>
