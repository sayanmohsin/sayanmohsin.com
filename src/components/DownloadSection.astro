---
import ProjectLinks from "./ProjectLinks.astro"

interface Props {
  accent?: string
}

const { accent = "#6b80ff" } = Astro.props

const MANIFEST_URL = "https://storage.googleapis.com/clipstash-releases/versions.json"

interface VersionManifest {
  latest: string
  versions: { version: string; date: string; files: Record<string, { url: string }> }[]
}

const platforms = [
  { key: "macos-arm", label: "macOS (Apple Silicon)" },
  { key: "macos-intel", label: "macOS (Intel)" },
  { key: "windows", label: "Windows" },
  { key: "linux", label: "Linux" },
]

let manifest: VersionManifest | null = null
try {
  const res = await fetch(MANIFEST_URL)
  if (res.ok) manifest = await res.json()
} catch {}

const latest = manifest?.versions.find((v) => v.version === manifest?.latest)
const links = latest
  ? platforms
      .filter((p) => latest.files[p.key])
      .map((p) => ({
        type: "download" as const,
        url: latest.files[p.key].url,
        label: p.label,
      }))
  : []
---

{
  links.length > 0 && (
    <div class="mt-8">
      <p class="mono text-xs text-dim/60 tracking-[0.1em] uppercase">Downloads</p>
      <p class="mt-1 text-xs text-dim/40 mono">v{latest!.version} · {latest!.date}</p>
      <ProjectLinks links={links} accent={accent} />
    </div>
  )
}
