---
const MANIFEST_URL = "https://storage.googleapis.com/clipstash-releases/versions.json"

interface VersionManifest {
  latest: string
  versions: { version: string; date: string; files: Record<string, { url: string }> }[]
}

const platforms = [
  { key: "macos-arm", label: "macOS (Apple Silicon)", short: "mac-arm" },
  { key: "macos-intel", label: "macOS (Intel)", short: "mac-intel" },
  { key: "windows", label: "Windows", short: "win" },
  { key: "linux", label: "Linux", short: "linux" },
]

let manifest: VersionManifest | null = null
try {
  const res = await fetch(MANIFEST_URL)
  if (res.ok) manifest = await res.json()
} catch {}

const latest = manifest?.versions.find((v) => v.version === manifest?.latest)
const links = latest
  ? platforms
      .filter((p) => latest.files[p.key])
      .map((p) => ({ url: latest.files[p.key].url, short: p.short, label: p.label }))
  : []
---

{
  links.length > 0 && (
    <div class="mt-8">
      <p class="mono text-xs text-dim/40 tracking-[0.1em] uppercase">Downloads</p>
      <div class="mt-3 space-y-1 mono text-sm">
        {links.map((l) => (
          <div>
            <a href={l.url} class="text-dim hover:text-fg transition-colors">
              <span class="text-dim/50">[{l.short}]</span> {l.label}
            </a>
          </div>
        ))}
      </div>
      <p class="mt-2 text-xs text-dim/40 mono">v{latest!.version} · {latest!.date}</p>
    </div>
  )
}
