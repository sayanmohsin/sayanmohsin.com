<div id="clipstash-downloads" class="mt-8 hidden">
  <p class="mono text-xs text-dim/40 tracking-[0.1em] uppercase">Downloads</p>
  <div id="dl-list" class="mt-3 space-y-1 mono text-sm"></div>
  <div id="dl-meta" class="mt-2 text-xs text-dim/40 mono"></div>
</div>

<script is:inline>
(function () {
  var MANIFEST_URL = "https://storage.googleapis.com/clipstash-releases/versions.json"
  var PLATFORMS = [
    { key: "macos-arm", label: "macOS (Apple Silicon)", short: "mac-arm" },
    { key: "macos-intel", label: "macOS (Intel)", short: "mac-intel" },
    { key: "windows", label: "Windows", short: "win" },
    { key: "linux", label: "Linux", short: "linux" },
  ]

  var container = document.getElementById("clipstash-downloads")
  var list = document.getElementById("dl-list")
  var meta = document.getElementById("dl-meta")

  if (!container) return

  fetch(MANIFEST_URL)
    .then(function (res) {
      if (!res.ok) throw new Error("Failed: " + res.status)
      return res.json()
    })
    .then(function (manifest) {
      var latest = manifest.versions.find(function (v) { return v.version === manifest.latest })
      if (!latest) return

      var lines = []
      for (var i = 0; i < PLATFORMS.length; i++) {
        var p = PLATFORMS[i]
        var file = latest.files[p.key]
        if (!file) continue
        lines.push(
          '<div><a href="' + file.url + '" class="text-dim hover:text-fg transition-colors"><span class="text-dim/50">[' + p.short + ']</span> ' + p.label + '</a></div>'
        )
      }

      if (lines.length === 0) return

      list.innerHTML = lines.join("")
      meta.textContent = "v" + latest.version + " \u00b7 " + latest.date
      container.classList.remove("hidden")
    })
    .catch(function () {})
})()
</script>
