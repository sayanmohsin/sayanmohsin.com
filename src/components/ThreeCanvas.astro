<script>
import * as THREE from "three"

const canvas = document.getElementById("three-canvas") as HTMLCanvasElement
if (!canvas) throw new Error("Canvas not found")

const isMobile = window.innerWidth < 640

const scene = new THREE.Scene()
const camera = new THREE.PerspectiveCamera(45, canvas.clientWidth / canvas.clientHeight, 0.1, 100)
camera.position.z = 4

const renderer = new THREE.WebGLRenderer({
  canvas,
  alpha: true,
  antialias: !isMobile,
})
renderer.setSize(canvas.clientWidth, canvas.clientHeight)
renderer.setPixelRatio(isMobile ? 1 : Math.min(window.devicePixelRatio, 2))

const ringCount = isMobile ? 2 : 3
const rings: THREE.Mesh[] = []
const color = new THREE.Color("#ffd700")

for (let i = 0; i < ringCount; i++) {
  const radius = 1.2 + i * 0.6
  const geo = new THREE.TorusGeometry(radius, 0.02, 32, 64)
  const mat = new THREE.ShaderMaterial({
    uniforms: {
      uTime: { value: 0 },
      uOffset: { value: i * 0.5 },
      uColor: { value: color },
    },
    vertexShader: `
      uniform float uTime;
      uniform float uOffset;
      varying float vAlpha;
      void main() {
        vec3 pos = position;
        float wave = sin(uTime * 0.6 + uOffset + pos.x * 0.5) * 0.04;
        pos.y += wave;
        vAlpha = 0.3 + 0.7 * (0.5 + 0.5 * sin(uTime * 0.4 + uOffset));
        gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
      }
    `,
    fragmentShader: `
      uniform vec3 uColor;
      varying float vAlpha;
      void main() {
        float glow = 0.6 + 0.4 * sin(vAlpha * 6.28);
        gl_FragColor = vec4(uColor, glow * 0.4 * vAlpha);
      }
    `,
    transparent: true,
    side: THREE.DoubleSide,
    depthWrite: false,
    blending: THREE.AdditiveBlending,
  })
  const mesh = new THREE.Mesh(geo, mat)
  mesh.rotation.x = Math.PI * 0.3
  scene.add(mesh)
  rings.push(mesh)
}

const innerRing = new THREE.Mesh(
  new THREE.TorusGeometry(0.5, 0.015, 24, 48),
  new THREE.ShaderMaterial({
    uniforms: { uTime: { value: 0 }, uColor: { value: color } },
    vertexShader: `
      uniform float uTime;
      varying float vAlpha;
      void main() {
        vec3 pos = position;
        pos.x += sin(uTime * 0.8 + pos.y * 2.0) * 0.03;
        vAlpha = 0.4 + 0.6 * (0.5 + 0.5 * sin(uTime * 0.6));
        gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
      }
    `,
    fragmentShader: `
      uniform vec3 uColor;
      varying float vAlpha;
      void main() {
        gl_FragColor = vec4(uColor, vAlpha * 0.5);
      }
    `,
    transparent: true,
    depthWrite: false,
    blending: THREE.AdditiveBlending,
  })
)
innerRing.rotation.x = Math.PI * 0.3
scene.add(innerRing)
rings.push(innerRing)

let clock = new THREE.Clock()

function animate() {
  requestAnimationFrame(animate)
  const t = clock.getElapsedTime()

  rings.forEach((ring, i) => {
    ring.material.uniforms.uTime.value = t
    ring.rotation.z = t * (0.05 + i * 0.02)
  })

  renderer.render(scene, camera)
}

animate()

function resize() {
  const w = canvas.clientWidth
  const h = canvas.clientHeight
  renderer.setSize(w, h)
  camera.aspect = w / h
  camera.updateProjectionMatrix()
}

window.addEventListener("resize", resize)
</script>

<canvas
  id="three-canvas"
  class="pointer-events-none fixed inset-0 z-0 h-screen w-screen"
  style="will-change: transform"
/>
