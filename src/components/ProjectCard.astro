---
import type { Project } from "../data/projects"
export interface Props {
  project: Project
  index: number
}
const { project, index } = Astro.props
---

<div
  class="group relative overflow-hidden rounded-xl border border-border bg-bg-card transition-all duration-300 hover:border-accent-500/30 hover:shadow-[0_0_30px_#ff6b0010]"
  style={`animation: fade-up 0.6s ease-out ${index * 0.1}s forwards; opacity: 0;`}
>
  {project.featured && (
    <div class="absolute -right-12 -top-12 h-24 w-24 rotate-45 bg-accent-500/10 blur-xl" />
  )}
  <div class="flex h-full flex-col p-5 sm:p-6">
    <div class="mb-3 flex items-start justify-between">
      <span class="text-2xl">{project.emoji}</span>
      {project.featured && (
        <span class="rounded-full border border-accent-500/20 bg-accent-500/10 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-accent-400">
          Featured
        </span>
      )}
    </div>

    <h3 class="font-display text-lg font-semibold text-text-primary">
      {project.name}
    </h3>
    <p class="mt-1 text-sm font-medium text-accent-400">{project.tagline}</p>
    <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">
      {project.description}
    </p>

    <div class="mt-4 flex flex-wrap gap-1.5">
      {project.tags.map((tag) => (
        <span class="rounded-md border border-border bg-bg-hover px-2 py-0.5 font-mono text-[11px] text-text-muted">
          {tag}
        </span>
      ))}
    </div>

    <div class="mt-4 flex items-center gap-3 border-t border-border pt-4">
      {project.githubUrl && (
        <a
          href={project.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-xs font-medium text-text-muted transition-colors hover:text-accent-400"
        >
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          Source
        </a>
      )}
      {project.websiteUrl && (
        <a
          href={project.websiteUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-xs font-medium text-text-muted transition-colors hover:text-accent-400"
        >
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M21 21 3 3"/><path d="M21 3l-9 9"/></svg>
          Website
        </a>
      )}
    </div>
  </div>
</div>
