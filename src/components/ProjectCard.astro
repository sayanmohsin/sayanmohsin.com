---
import type { Project } from "../data/projects"
export interface Props {
  project: Project
  index: number
}
const { project, index } = Astro.props
---

<a
  href={`/projects/${project.slug}`}
  class="group relative block overflow-hidden rounded-xl border border-border bg-bg-card transition-all duration-300 hover:border-text-subtle"
  style={`animation: fade-up 0.6s ease-out ${index * 0.1}s forwards; opacity: 0;`}
>
  <div class="flex h-full flex-col p-5 sm:p-6">
    <div class="mb-4 flex items-start justify-between">
      <span class="text-2xl">{project.emoji}</span>
      {project.featured && (
        <span class="rounded-full border border-accent/20 bg-accent-subtle px-2.5 py-0.5 font-mono text-[10px] font-medium text-accent">
          featured
        </span>
      )}
    </div>

    <h3 class="text-lg font-medium text-text-primary">
      {project.name}
    </h3>
    <p class="mt-1 text-sm text-accent">{project.tagline}</p>
    <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">
      {project.description}
    </p>

    <div class="mt-4 flex flex-wrap gap-1.5">
      {project.tags.map((tag) => (
        <span class="rounded-md border border-border bg-bg-hover px-2 py-0.5 font-mono text-[11px] text-text-muted">
          {tag}
        </span>
      ))}
    </div>

    <div class="mt-4 flex items-center gap-1.5 border-t border-border pt-4 text-xs text-text-dim transition-all duration-200 group-hover:text-text-muted">
      <span>View details</span>
      <svg class="h-3.5 w-3.5 transition-transform duration-200 group-hover:translate-x-0.5" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </div>
  </div>
</a>
