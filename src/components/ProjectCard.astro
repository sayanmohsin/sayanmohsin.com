---
import type { Project } from "../data/projects"
export interface Props {
  project: Project
  index: number
}
const { project, index } = Astro.props
const colors = ["orange", "green", "yellow"] as const
const color = colors[index % colors.length]

const borderColor = {
  orange: "hover:border-orange-500/30 hover:shadow-[0_0_30px_#ff6b0010]",
  green: "hover:border-green-500/30 hover:shadow-[0_0_30px_#00ff8810]",
  yellow: "hover:border-yellow-500/30 hover:shadow-[0_0_30px_#ffd70010]",
}
const glowClass = {
  orange: "glow-orange",
  green: "glow-green",
  yellow: "glow-yellow",
}
const statusColor = {
  orange: "bg-orange-500 shadow-[0_0_6px_#ff6b00]",
  green: "bg-green-500 shadow-[0_0_6px_#00ff88]",
  yellow: "bg-yellow-500 shadow-[0_0_6px_#ffd700]",
}
const tagColor = {
  orange: "text-orange-500 border-orange-500/20",
  green: "text-green-500 border-green-500/20",
  yellow: "text-yellow-500 border-yellow-500/20",
}
const headerGradient = {
  orange: "gradient-text-orange",
  green: "gradient-text-green",
  yellow: "gradient-text-yellow",
}
const accentClass = {
  orange: "text-orange-500",
  green: "text-green-500",
  yellow: "text-yellow-500",
}
---

<a
  href={`/projects/${project.slug}`}
  class={`group relative block overflow-hidden rounded-xl border border-border bg-bg-card transition-all duration-300 ${borderColor[color]}`}
  style={`animation: fade-up 0.6s ease-out ${index * 0.1}s forwards; opacity: 0;`}
>
  <div class="flex h-full flex-col p-5 sm:p-6">
    <div class="mb-3 flex items-start justify-between">
      <div class="flex items-center gap-3">
        <span class="text-2xl">{project.emoji}</span>
        <span class={`status-dot ${statusColor[color]}`} />
      </div>
      {project.featured && (
        <span class="rounded-full border border-orange-500/20 bg-orange-500/10 px-2.5 py-0.5 font-mono text-[10px] font-semibold uppercase tracking-wider text-orange-500">
          Featured
        </span>
      )}
    </div>

    <h3 class={`font-display text-lg font-semibold ${headerGradient[color]}`}>
      {project.name}
    </h3>
    <p class={`mt-1 text-sm font-medium ${accentClass[color]}`}>{project.tagline}</p>
    <p class="mt-2 flex-1 text-sm leading-relaxed text-text-muted">
      {project.description}
    </p>

    <div class="mt-4 flex flex-wrap gap-1.5">
      {project.tags.map((tag) => (
        <span class={`rounded-md border ${tagColor[color]} bg-bg-hover px-2 py-0.5 font-mono text-[11px] text-text-muted`}>
          {tag}
        </span>
      ))}
    </div>

    <div class="mt-4 flex items-center gap-3 border-t border-border pt-4 text-xs text-text-dim">
      <span class={`font-mono flex items-center gap-1 ${accentClass[color]} group-hover:gap-2 transition-all`}>
        View details →
      </span>
    </div>
  </div>
</a>
