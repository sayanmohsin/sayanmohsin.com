---

<section id="contact" class="border-t border-border px-4 py-24 sm:px-6 sm:py-32">
  <div class="mx-auto max-w-2xl text-center">
    <div class="mb-3 font-mono text-xs text-text-dim">/contact</div>

    <h2 class="text-2xl font-light tracking-tight text-text-primary sm:text-3xl">
      Get in touch
    </h2>

    <p class="mt-3 text-sm text-text-muted">
      Building something interesting? I'm always open to new ideas.
    </p>

    <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
      <a
        href="mailto:sayanmohsin@outlook.com"
        class="rounded-lg bg-accent px-5 py-3 text-sm font-medium text-white transition-all duration-200 hover:bg-accent-hover"
      >
        sayanmohsin@outlook.com
      </a>
      <a
        href="https://github.com/sayanmohsin"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-lg border border-border bg-bg-card px-5 py-3 text-sm text-text-muted transition-all duration-200 hover:border-text-subtle hover:text-text-primary"
      >
        GitHub
      </a>
    </div>

    <div class="mt-24 border-t border-border pt-6">
      <p class="text-xs text-text-dim">
        &copy; {new Date().getFullYear()} Sayan Mohsin
      </p>
      <p class="mt-1 text-xs text-text-dim/50">
        Built with Rust and ☕
      </p>
    </div>
  </div>
</section>
