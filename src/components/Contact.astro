---

<section id="contact" class="section mx-auto mt-20 max-w-2xl">
  <div class="text-dim space-y-1">
    <div>
      <span class="prompt">$</span> cat <span class="text-dim">~/contact</span>
    </div>
    <div class="ml-4 mt-3 space-y-0.5">
      <a href="mailto:sayanmohsin@outlook.com">sayanmohsin@outlook.com</a>
      <br />
      <a href="https://github.com/sayanmohsin" target="_blank" rel="noopener noreferrer">github.com/sayanmohsin</a>
      <br />
      <a href="https://linkedin.com/in/sayanmohsin" target="_blank" rel="noopener noreferrer">linkedin.com/in/sayanmohsin</a>
    </div>
  </div>

  <div class="mt-20 pt-6 text-dim/40 text-[12px]">
    <span class="prompt">$</span> echo "© {new Date().getFullYear()} Sayan Mohsin"<span class="cursor"></span>
  </div>
</section>
