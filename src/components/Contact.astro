---

<section id="contact" class="relative px-4 py-24 sm:px-6 sm:py-32">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute -top-20 left-1/4 h-48 w-48 rounded-full bg-orange-500/5 blur-[96px]" />
  </div>

  <div class="relative z-10 mx-auto max-w-2xl text-center">
    <div class="panel-header mb-2 justify-center">
      <span class="gradient-text-orange">Connect</span>
    </div>

    <h2 class="mt-4 font-display text-3xl font-bold tracking-tight sm:text-4xl">
      <span class="gradient-text-orange">Get in touch</span>
    </h2>

    <p class="mt-3 font-mono text-sm leading-relaxed text-text-muted">
      $ echo "Building something interesting?"
    </p>

    <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a
        href="mailto:sayanmohsin@outlook.com"
        class="inline-flex items-center gap-2 rounded-xl bg-orange-500 px-6 py-3 font-mono font-semibold text-white transition-all duration-200 hover:bg-orange-400 hover:glow-orange"
      >
        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        sayanmohsin@outlook.com
      </a>
      <a
        href="https://github.com/sayanmohsin"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-xl border border-border bg-bg-card px-6 py-3 font-mono font-medium text-text-muted transition-all duration-200 hover:border-green-500/30 hover:text-green-500 hover:glow-green"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        GitHub
      </a>
    </div>

    <div class="mt-16 border-t border-border pt-8">
      <div class="font-mono text-xs text-text-dim">
        <span class="gradient-text-orange">$</span> echo "© {new Date().getFullYear()} Sayan Mohsin. Built with Rust and ☕."
      </div>
      <div class="mt-1 font-mono text-[11px] text-text-dim/50">
        Ship_Fast.exe &amp;&amp; Pivot_Faster.exe
      </div>
    </div>
  </div>
</section>
