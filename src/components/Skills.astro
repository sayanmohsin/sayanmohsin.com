---

<section id="skills" class="section mx-auto mt-20 max-w-2xl">
  <div class="text-dim space-y-1">
    <div>
      <span class="prompt">$</span> cat <span class="text-dim">~/.skills</span>
    </div>
    <div class="ml-4 mt-3 space-y-2">
      <div>
        <span class="text-dim/60 text-[13px]">Languages</span>
        <span class="ml-2 text-fg">TypeScript · Java · Python · Go · PHP</span>
      </div>
      <div>
        <span class="text-dim/60 text-[13px]">Frontend</span>
        <span class="ml-2 text-fg">React · Next.js · Angular · Vue · Vite</span>
      </div>
      <div>
        <span class="text-dim/60 text-[13px]">Backend</span>
        <span class="ml-2 text-fg">Spring · NestJS · FastAPI · Kafka · Temporal</span>
      </div>
      <div>
        <span class="text-dim/60 text-[13px]">Runtime</span>
        <span class="ml-2 text-fg">Node.js · Bun · Kubernetes · Docker · ArgoCD</span>
      </div>
    </div>
  </div>
</section>
