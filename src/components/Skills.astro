---

<section id="skills" class="section mx-auto mt-20 max-w-2xl px-4 sm:px-0">
  <p class="mono text-xs text-dim/40 tracking-[0.1em] uppercase">Skills</p>

  <div class="mt-6 space-y-2 text-sm leading-relaxed">
    <div>
      <span class="mono text-dim/40 text-[13px]">Languages</span>
      <span class="text-dim"> &nbsp;TypeScript · Java · Python · Go · PHP</span>
    </div>
    <div>
      <span class="mono text-dim/40 text-[13px]">Frontend</span>
      <span class="text-dim"> &nbsp;React · Next.js · Angular · Vue · Vite</span>
    </div>
    <div>
      <span class="mono text-dim/40 text-[13px]">Backend</span>
      <span class="text-dim"> &nbsp;Spring · NestJS · FastAPI · Kafka · Temporal</span>
    </div>
    <div>
      <span class="mono text-dim/40 text-[13px]">Runtime</span>
      <span class="text-dim"> &nbsp;Node.js · Bun · Kubernetes · Docker · ArgoCD</span>
    </div>
  </div>
</section>
