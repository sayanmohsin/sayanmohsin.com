---
const skillGroups = [
  {
    label: "Languages",
    items: ["TypeScript", "Java", "Python", "Go", "PHP"],
  },
  {
    label: "Frontend",
    items: ["React", "Next.js", "Angular", "Vue", "Vite"],
  },
  {
    label: "Backend",
    items: ["Spring", "NestJS", "FastAPI", "Kafka", "Temporal"],
  },
  {
    label: "Runtime",
    items: ["Node.js", "Bun"],
  },
  {
    label: "DevOps",
    items: ["Kubernetes", "Docker", "ArgoCD"],
  },
]
const allSkills = skillGroups.flatMap((g) => g.items)
const marqueeItems = [...allSkills, ...allSkills]
const colors = ["orange", "green", "yellow"] as const
---

<section id="skills" class="relative px-4 py-24 sm:px-6 sm:py-32">
  <div class="mx-auto max-w-5xl">
    <div class="mb-12">
      <div class="panel-header mb-2">
        <span class="gradient-text-yellow">Capabilities</span>
      </div>
      <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">
        <span class="gradient-text-yellow">Skills</span>
      </h2>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {skillGroups.map((group, gi) => {
        const c = colors[gi % colors.length]
        const borderKey = `hover:border-${c}-500/30`
        const accentKey = `text-${c}-500`
        return (
          <div class={`rounded-xl border border-border bg-bg-card p-4 sm:p-5 transition-all duration-200 hover:border-${c}-500/30`}>
            <h3 class={`mb-3 font-mono text-xs font-semibold uppercase tracking-wider text-${c}-500`}>
              {group.label}
            </h3>
            <div class="flex flex-wrap gap-2">
              {group.items.map((skill) => (
                <span
                  class={`rounded-lg border border-border bg-bg-hover px-3 py-1.5 font-mono text-sm text-text-muted transition-all duration-200 hover:border-${c}-500/30 hover:text-${c}-500`}
                >
                  {skill}
                </span>
              ))}
            </div>
          </div>
        )
      })}
    </div>

    <div class="mt-12 overflow-hidden">
      <div class="flex animate-marquee gap-3">
        {marqueeItems.map((skill, i) => {
          const c = colors[i % colors.length]
          return (
            <span
              class={`inline-flex shrink-0 items-center gap-2 rounded-full border border-${c}-500/20 bg-bg-card px-4 py-2 font-mono text-sm text-text-muted`}
            >
              <span class={`h-1.5 w-1.5 rounded-full bg-${c}-500`} />
              {skill}
            </span>
          )
        })}
      </div>
    </div>
  </div>
</section>
