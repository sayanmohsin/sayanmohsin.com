---
const skillGroups = [
  {
    label: "Languages",
    items: ["TypeScript", "Java", "Python", "Go", "PHP"],
  },
  {
    label: "Frontend",
    items: ["React", "Next.js", "Angular", "Vue", "Vite"],
  },
  {
    label: "Backend",
    items: ["Spring", "NestJS", "FastAPI", "Kafka", "Temporal"],
  },
  {
    label: "Runtime & DevOps",
    items: ["Node.js", "Bun", "Kubernetes", "Docker", "ArgoCD"],
  },
]
---

<section id="skills" class="border-t border-border px-4 py-24 sm:px-6 sm:py-32">
  <div class="mx-auto max-w-5xl">
    <div class="mb-14 text-center">
      <div class="mb-3 font-mono text-xs text-text-dim">/skills</div>
      <h2 class="text-2xl font-light tracking-tight text-text-primary sm:text-3xl">
        Skills
      </h2>
    </div>

    <div class="grid gap-3 sm:grid-cols-2">
      {skillGroups.map((group) => (
        <div class="rounded-xl border border-border bg-bg-card p-5">
          <h3 class="mb-4 text-xs font-medium uppercase tracking-wider text-text-muted">
            {group.label}
          </h3>
          <div class="flex flex-wrap gap-2">
            {group.items.map((skill) => (
              <span class="rounded-md border border-border bg-bg-hover px-3 py-1.5 text-sm text-text-muted transition-colors hover:border-text-subtle hover:text-text-primary">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
