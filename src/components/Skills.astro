---
const skillGroups = [
  {
    label: "Languages",
    items: ["TypeScript", "Java", "Python", "Go", "PHP"],
  },
  {
    label: "Frontend",
    items: ["React", "Next.js", "Angular", "Vue", "Vite"],
  },
  {
    label: "Backend",
    items: ["Spring", "NestJS", "FastAPI", "Kafka", "Temporal"],
  },
  {
    label: "Runtime",
    items: ["Node.js", "Bun"],
  },
  {
    label: "DevOps",
    items: ["Kubernetes", "Docker", "ArgoCD"],
  },
]
const allSkills = skillGroups.flatMap((g) => g.items)
const marqueeItems = [...allSkills, ...allSkills]
---

<section id="skills" class="relative px-4 py-24 sm:px-6 sm:py-32">
  <div class="mx-auto max-w-5xl">
    <div class="mb-12 text-center">
      <span class="mb-2 inline-block font-mono text-xs text-text-muted">
        <span class="gradient-text">$</span> cat skills.dat
      </span>
      <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">
        <span class="gradient-text">Skills</span>
      </h2>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {skillGroups.map((group) => (
        <div class="glow-border rounded-xl border border-border bg-bg-card p-4 sm:p-5">
          <h3 class="mb-3 font-mono text-xs font-semibold uppercase tracking-wider text-accent-400">
            {group.label}
          </h3>
          <div class="flex flex-wrap gap-2">
            {group.items.map((skill) => (
              <span
                class="rounded-lg border border-border bg-bg-hover px-3 py-1.5 font-mono text-sm text-text-muted transition-all duration-200 hover:border-accent-500/30 hover:text-accent-400"
              >
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 overflow-hidden">
      <div class="flex animate-marquee gap-3">
        {marqueeItems.map((skill, i) => (
          <span
            class="inline-flex shrink-0 items-center gap-2 rounded-full border border-border bg-bg-card px-4 py-2 font-mono text-sm text-text-muted"
          >
            <span class="h-1.5 w-1.5 rounded-full bg-accent-500" />
            {skill}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
