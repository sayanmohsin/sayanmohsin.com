<script>
  import { animate, inView } from "motion"

  inView(
    "#projects, #skills, #contact",
    ({ target }) => {
      animate(
        target,
        { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0)"] },
        { duration: 0.6, easing: "ease-out" }
      )
    },
    { amount: 0.2 }
  )
</script>
