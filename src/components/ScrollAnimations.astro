<script>
  import { animate, inView } from "motion"

  inView(
    ".section",
    ({ target }) => {
      animate(
        target,
        { opacity: [0, 1], transform: ["translateY(12px)", "translateY(0)"] },
        { duration: 0.5, easing: "ease-out" }
      )
    },
    { amount: 0.3 }
  )
</script>
