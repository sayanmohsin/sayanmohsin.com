<script>
  import { animate, inView, scroll } from "motion"

  inView(
    ".section",
    ({ target }) => {
      animate(
        target,
        { opacity: [0, 1], transform: ["translateY(12px)", "translateY(0)"] },
        { duration: 0.5, easing: "ease-out" }
      )
    },
    { amount: 0.3 }
  )

  document.querySelectorAll("hr.signal").forEach((hr) => {
    scroll(
      animate(hr, { transform: ["scaleX(0)", "scaleX(1)"] }, { easing: "ease-out", duration: 0.8 }),
      { target: hr, offset: ["start end", "end center"] }
    )
  })
</script>
