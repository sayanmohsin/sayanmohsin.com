---
import type { Project } from "../data/projects"
export interface Props {
  project: Project
}

const { project } = Astro.props
const colors = ["orange", "green", "yellow"] as const
const colorNum = project.slug.length % 3
const color = colors[colorNum]

const accentColors = {
  orange: { text: "text-orange-500", border: "border-orange-500/30", gradient: "gradient-text-orange", bg: "bg-orange-500" },
  green: { text: "text-green-500", border: "border-green-500/30", gradient: "gradient-text-green", bg: "bg-green-500" },
  yellow: { text: "text-yellow-500", border: "border-yellow-500/30", gradient: "gradient-text-yellow", bg: "bg-yellow-500" },
}
const c = accentColors[color]
---

<section class="min-h-screen px-4 pt-20 pb-24 sm:px-6 sm:pt-28">
  <div class="mx-auto max-w-3xl">
    <a
      href="/"
      class="mb-8 inline-flex items-center gap-1.5 font-mono text-sm text-text-dim transition-colors hover:text-text-muted"
    >
      <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Back to dashboard
    </a>

    <div class="mb-8 flex items-center gap-3">
      <span class="text-4xl">{project.emoji}</span>
      <div>
        <div class="flex items-center gap-2">
          <span class={`inline-block h-2 w-2 rounded-full ${c.bg} shadow-[0_0_6px_currentColor]`} />
          <span class="font-mono text-[10px] uppercase tracking-wider text-text-dim">Service</span>
        </div>
        <h1 class={`font-display text-3xl font-bold sm:text-4xl ${c.gradient}`}>
          {project.name}
        </h1>
      </div>
    </div>

    <div class="mb-8 flex flex-wrap gap-2">
      {project.tags.map((tag) => (
        <span class={`rounded-md border ${c.border} bg-bg-hover px-2.5 py-1 font-mono text-xs ${c.text}`}>
          {tag}
        </span>
      ))}
    </div>

    <div class="glow-border mb-8 rounded-xl border border-border bg-bg-card p-6 sm:p-8">
      <p class="text-lg font-medium leading-relaxed text-text-primary">
        {project.tagline}
      </p>
      <div class="mt-4 h-px bg-border" />
      <p class="mt-4 leading-relaxed text-text-muted">
        {project.fullDescription}
      </p>
    </div>

    <div class="flex flex-wrap gap-3">
      {project.githubUrl && (
        <a
          href={project.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class={`inline-flex items-center gap-2 rounded-xl ${c.bg} px-5 py-3 font-mono text-sm font-semibold text-white transition-all duration-200 hover:opacity-90 glow-${color}`}
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          View Source
        </a>
      )}
      {project.websiteUrl && (
        <a
          href={project.websiteUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl border border-border bg-bg-card px-5 py-3 font-mono text-sm font-medium text-text-muted transition-all duration-200 hover:text-white"
        >
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M21 21 3 3"/><path d="M21 3l-9 9"/></svg>
          Visit Website
        </a>
      )}
    </div>

    {project.downloads && project.downloads.length > 0 && (
      <div class="mt-10">
        <div class="panel-header mb-4">
          <span class="gradient-text-green">Downloads</span>
        </div>
        <div class="grid gap-3 sm:grid-cols-2">
          {project.downloads.map((dl) => {
            const osIcon = {
              mac: "🍎",
              windows: "🪟",
              linux: "🐧",
              ios: "📱",
              android: "🤖",
            }
            return (
              <a
                href={dl.url}
                class="flex items-center gap-3 rounded-xl border border-border bg-bg-card px-4 py-3 transition-all duration-200 hover:border-green-500/30"
              >
                <span class="text-xl">{osIcon[dl.os]}</span>
                <span class="font-mono text-sm text-text-muted">{dl.label}</span>
              </a>
            )
          })}
        </div>
      </div>
    )}
  </div>
</section>
