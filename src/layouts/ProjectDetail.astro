---
import type { Project } from "../data/projects"
import ProjectLinks from "../components/ProjectLinks.astro"
import DownloadSection from "../components/DownloadSection.astro"
export interface Props {
  project: Project
}
const { project } = Astro.props

const accentMap: Record<string, string> = {
  thingd: "#ff6b00",
  clipbuf: "#6b80ff",
  dartcam: "#ff6b6b",
  "thingd-cloud": "#ff8c00",
}
const accent = accentMap[project.slug] || "#ff6b00"
---

<section class="mx-auto max-w-2xl px-4 py-16 sm:px-0 sm:py-28">
  <a href="/projects" class="mono text-sm text-dim hover:text-fg transition-colors">&larr; all projects</a>

  <div class="mt-12 flex items-center gap-3">
    <span class="text-3xl">{project.emoji}</span>
    <div>
      <p class="mono text-xs text-dim/40 tracking-[0.1em] uppercase">Project</p>
      <h1 class="text-2xl font-light tracking-tight sm:text-3xl" style={`color: ${accent}`}>{project.name}</h1>
    </div>
  </div>

  <p class="mt-3 text-dim">{project.tagline}</p>

  <div class="mt-3 flex flex-wrap gap-x-3 mono text-[13px] text-dim/40">
    {project.tags.map((tag) => (
      <span>{tag}</span>
    ))}
  </div>

  <div class="mt-8 pl-5 accent-line leading-relaxed text-dim" style={`border-left-color: ${accent}40`}>
    <p>{project.fullDescription}</p>
  </div>

  {project.links && project.links.length > 0 && (
    <ProjectLinks links={project.links} accent={accent} />
  )}

  {project.slug === "clipbuf" && <DownloadSection accent={accent} />}
</section>
