---
import type { Project } from "../data/projects"
export interface Props {
  project: Project
}
const { project } = Astro.props
---

<section class="mx-auto max-w-2xl">
  <div class="mb-10 text-dim space-y-1">
    <div>
      <span class="prompt">$</span> cat <span class="text-dim">~/projects/{project.slug}/README.md</span>
    </div>
  </div>

  <div class="flex items-center gap-2 text-fg">
    <span class="text-xl">{project.emoji}</span>
    <h1 class="text-xl font-medium sm:text-2xl">{project.name}</h1>
  </div>

  <p class="mt-1 text-accent">{project.tagline}</p>

  <div class="mt-4 flex flex-wrap gap-x-2 gap-y-1">
    {project.tags.map((tag) => (
      <span class="text-[12px] text-dim/60">#{tag}</span>
    ))}
  </div>

  <div class="mt-6 border-l border-line pl-4 text-dim leading-relaxed">
    {project.fullDescription}
  </div>

  <div class="mt-6 space-y-2">
    {project.githubUrl && (
      <div>
        <span class="text-dim/60 text-[13px]">github:</span>{' '}
        <a href={project.githubUrl} target="_blank" rel="noopener noreferrer">
          {project.githubUrl.replace("https://", "")}
        </a>
      </div>
    )}
    {project.websiteUrl && (
      <div>
        <span class="text-dim/60 text-[13px]">website:</span>{' '}
        <a href={project.websiteUrl} target="_blank" rel="noopener noreferrer">
          {project.websiteUrl}
        </a>
      </div>
    )}
  </div>

  {project.downloads && project.downloads.length > 0 && (
    <div class="mt-8">
      <div class="text-dim/60 text-[13px] mb-2">downloads:</div>
      <div class="space-y-1">
        {project.downloads.map((dl) => (
          <div>
            <a href={dl.url}>
              <span class="text-dim/60 text-[13px]">[{dl.os}]</span> {dl.label}
            </a>
          </div>
        ))}
      </div>
    </div>
  )}

  <div class="mt-12">
    <a href="/" class="text-dim hover:text-accent transition-colors">
      ← back
    </a>
  </div>
</section>
