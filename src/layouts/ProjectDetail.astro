---
import type { Project } from "../data/projects"
import DownloadSection from "../components/DownloadSection.astro"
export interface Props {
  project: Project
}
const { project } = Astro.props

const accentMap: Record<string, string> = {
  thingd: "#ff6b00",
  clipstash: "#6b80ff",
  dartcam: "#ff6b6b",
  "thingd-cloud": "#ff8c00",
}
const accent = accentMap[project.slug] || "#ff6b00"
---

<section class="mx-auto max-w-2xl px-4 py-16 sm:px-0 sm:py-28">
  <a href="/projects" class="mono text-sm text-dim hover:text-fg transition-colors">&larr; all projects</a>

  <div class="mt-12 flex items-center gap-3">
    <span class="text-3xl">{project.emoji}</span>
    <div>
      <p class="mono text-xs text-dim/40 tracking-[0.1em] uppercase">Project</p>
      <h1 class="text-2xl font-light tracking-tight sm:text-3xl" style={`color: ${accent}`}>{project.name}</h1>
    </div>
  </div>

  <p class="mt-3 text-dim">{project.tagline}</p>

  <div class="mt-3 flex flex-wrap gap-x-3 mono text-[13px] text-dim/40">
    {project.tags.map((tag) => (
      <span>{tag}</span>
    ))}
  </div>

  <div class="mt-8 pl-5 accent-line leading-relaxed text-dim" style={`border-left-color: ${accent}40`}>
    <p>{project.fullDescription}</p>
  </div>

  <div class="mt-8 space-y-1 mono text-sm">
    {project.githubUrl && (
      <div class="flex items-center gap-2">
        <svg class="h-4 w-4 shrink-0 text-[#ffd700]" style="filter:drop-shadow(0 0 6px rgba(255,215,0,0.35))" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="text-dim hover:text-fg transition-colors" style={`color: ${accent}`}>
          {project.githubUrl.replace("https://", "")}
        </a>
      </div>
    )}
    {project.websiteUrls?.map((url) => (
      <div class="flex items-center gap-2">
        <svg class="h-4 w-4 shrink-0 text-[#ffd700]" style="filter:drop-shadow(0 0 6px rgba(255,215,0,0.35))" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        <a href={url} target="_blank" rel="noopener noreferrer" class="text-dim hover:text-fg transition-colors" style={`color: ${accent}`}>
          {url.replace("https://", "")}
        </a>
      </div>
    ))}
  </div>

  {project.slug === "clipstash" ? (
    <DownloadSection />
  ) : project.downloads && project.downloads.length > 0 ? (
    <div class="mt-8">
      <p class="mono text-xs text-dim/40 tracking-[0.1em] uppercase">Downloads</p>
      <div class="mt-3 space-y-1 mono text-sm">
        {project.downloads.map((dl) => (
          <div>
            <a href={dl.url} class="text-dim hover:text-fg transition-colors">
              <span class="text-dim/50">[{dl.os}]</span> {dl.label}
            </a>
          </div>
        ))}
      </div>
    </div>
  ) : null}
</section>
